#include <stdio.h>

void url_encode(char *str, int true_length) {
    char temp[1000];
    int j = 0;

    for (int i = 0; i < true_length; i++) {
        if (str[i] == ' ') {
            temp[j++] = '%';
            temp[j++] = '2';
            temp[j++] = '0';
        } else {
            temp[j++] = str[i];
        }
    }
    temp[j] = '\0';

    for (int i = 0; temp[i] != '\0'; i++) {
        str[i] = temp[i];
    }
    str[j] = '\0';
}

int main() {
    char str[100] = "Hello World  ";
    url_encode(str, 11);
    printf("%s\n", str);
    return 0;
}